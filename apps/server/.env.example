BETTER_AUTH_SECRET=generate-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/pruvi
REDIS_URL=redis://localhost:6379

# Google Play OIDC verification (Phase 2E.10) — optional, defaults to disabled
# FOOTGUN: z.coerce.boolean() coerces ANY non-empty string (including the literal "false") to true.
# To DISABLE: leave GOOGLE_PLAY_VERIFY_OIDC unset or set to empty string.
# When enabled, both AUDIENCE and SERVICE_ACCOUNT_EMAIL are required at boot.
# GOOGLE_PLAY_VERIFY_OIDC=
# GOOGLE_PLAY_OIDC_AUDIENCE=https://api.pruvi.app/webhooks/google-play
# GOOGLE_PLAY_OIDC_SERVICE_ACCOUNT_EMAIL=pubsub-publisher@your-project.iam.gserviceaccount.com
