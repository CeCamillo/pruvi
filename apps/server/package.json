{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "dev:worker": "bun run --hot src/worker.ts",
    "start": "bun run dist/index.mjs",
    "start:worker": "bun run dist/worker.mjs",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.0.1",
    "@pruvi/auth": "workspace:*",
    "@pruvi/db": "workspace:*",
    "@pruvi/env": "workspace:*",
    "@pruvi/shared": "workspace:*",
    "better-auth": "catalog:",
    "bullmq": "^5.71.0",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.0",
    "neverthrow": "catalog:",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pruvi/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.18.0",
    "tsdown": "^0.16.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
