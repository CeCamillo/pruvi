{
  "name": "pruvi",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "dev:worker": "turbo -F server dev:worker",
    "db:push": "turbo -F @pruvi/db db:push",
    "db:studio": "turbo -F @pruvi/db db:studio",
    "db:generate": "turbo -F @pruvi/db db:generate",
    "db:migrate": "turbo -F @pruvi/db db:migrate",
    "db:start": "turbo -F @pruvi/db db:start",
    "db:watch": "turbo -F @pruvi/db db:watch",
    "db:stop": "turbo -F @pruvi/db db:stop",
    "db:down": "turbo -F @pruvi/db db:down",
    "db:seed": "turbo -F @pruvi/db db:seed",
    "verify:migration": "bun run scripts/verify-migration.ts"
  },
  "dependencies": {
    "@pruvi/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pruvi/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.28.0"
}
